# Pusher Channels credentials
# Get these from https://dashboard.pusher.com -> your app -> App Keys
# Copy this file to .env.local and fill in your real values.
# NEXT_PUBLIC_* vars are exposed to the browser (required for the client to
# connect); PUSHER_SECRET must stay server-only and never be prefixed with
# NEXT_PUBLIC_.

PUSHER_APP_ID=2177892
NEXT_PUBLIC_PUSHER_KEY=8d45966e54662d5fcae6
PUSHER_SECRET=30325c6015d57d30928e
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# Optional: absolute site URL, used to resolve Open Graph image URLs correctly
# once deployed. Set this to your production domain on Vercel.
# NEXT_PUBLIC_SITE_URL=https://spotlightwars.example.com

# --- Rock Paper Scissors (/rps) leaderboard storage ---
# Vercel KV itself is deprecated for new projects — from the Vercel dashboard,
# go to Marketplace -> Storage -> a Redis provider (e.g. Upstash for Redis)
# and add the integration. It provisions env vars under these same names for
# @vercel/kv backward compatibility, so no code changes are needed.
# Without these set, /rps still runs locally using an in-memory store: matches
# and moves work, but the leaderboard resets on every server restart.
# KV_REST_API_URL=https://your-instance.upstash.io
# KV_REST_API_TOKEN=your-rest-api-token
